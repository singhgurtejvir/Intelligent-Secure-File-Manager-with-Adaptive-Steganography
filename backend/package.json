    "@types/jest": "^29.5.5",
    "@types/multer": "^1.4.10",
    "@types/node": "^20.8.0",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^6.10.0",
    "@typescript-eslint/parser": "^6.10.0",
    "eslint": "^8.50.0",
    "jest": "^29.7.0",
