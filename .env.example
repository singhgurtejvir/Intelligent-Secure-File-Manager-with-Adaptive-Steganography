# Frontend
VITE_API_URL=http://localhost:3000

# Backend
NODE_ENV=development
PORT=3000
MONGODB_URI=mongodb://localhost:27017/secure-file-manager
JWT_SECRET=your-super-secret-jwt-key-change-in-production
CORS_ORIGIN=http://localhost:5173

# Message Broker (RabbitMQ or Redis)
RABBITMQ_URL=amqp://guest:guest@localhost:5672
REDIS_URL=redis://localhost:6379

# Python Worker
WORKER_HOST=localhost
WORKER_PORT=5000

# File Storage
MAX_FILE_SIZE=52428800
MAX_PAYLOAD_SIZE=10485760

# Encryption
AES_ALGORITHM=aes-256-gcm
SALT_ROUNDS=12

# Fingerprinting
FINGERPRINT_JS_KEY=your-fingerprintjs-public-key

# Steganography Settings
LSB_COLOR_THRESHOLD=10
DCT_QUALITY_FACTOR=85

# AWS S3 (optional)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=

# Logging
LOG_LEVEL=info
